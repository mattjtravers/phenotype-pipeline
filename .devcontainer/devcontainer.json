{
   "name": "Phenotype Pipeline",
   "features": {
      "ghcr.io/jsburckhardt/devcontainer-features/uv:1": {},
      "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
   },
   "customizations": {
      "vscode": {
         "extensions": [
            "ms-python.python",
            "ms-python.debugpy",
            "charliermarsh.ruff",
            "anthropic.claude-code"
         ],
         "settings": {
            "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
            "python.terminal.activateEnvInSelectedTerminal": true,
            "[python]": {
               "editor.formatOnSave": true,
               "editor.defaultFormatter": "charliermarsh.ruff",
               "editor.codeActionsOnSave": {
                  "source.organizeImports": "always",
                  "source.fixAll": "always"
               }
            },
            "claudeCode.preferredLocation": "sidebar",
            "claude.dangerouslySkipPermissions": true,
            "claude.initialPermissionMode": "bypassPermissions",
            "terminal.integrated.profiles.linux": {
               "bash": {
                  "path": "bash",
                  "icon": "terminal-bash"
               }
            }
         }
      }
   },
   "postCreateCommand": "uv venv && uv sync && \\
      claude plugin marketplace add jszmajda/lid && \\
      claude plugin install linked-intent-dev@jszmajda-lid && \\
      claude plugin install arrow-maintenance@jszmajda-lid"
}
